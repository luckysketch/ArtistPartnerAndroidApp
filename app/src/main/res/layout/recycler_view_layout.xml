<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_marginBottom="15dp"

   app:cardCornerRadius="10dp"
    android:elevation="5dp"
    android:layout_height="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <RelativeLayout
            android:padding="5dp"
            android:background="@color/bgcolor"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="match_parent">

            <TextView
                android:layout_marginLeft="5dp"
                android:id="@+id/recycler_project_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/black"
                android:textAllCaps="true"
                android:textSize="20sp"
                android:text="project_name"/>

            <TextView
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:text="Last Activity on "
                android:id="@+id/temp_text"
                android:layout_below="@id/recycler_project_name"/>
            <TextView
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="date"
                android:id="@+id/recycler_last_activity"
                android:layout_below="@id/recycler_project_name"
                android:layout_toRightOf="@id/temp_text"/>



        </RelativeLayout>
        <ImageView
            android:id="@+id/reference_img1"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/mainbgpic"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>

